-- ==================== MINIMIZE ====================
local function toggleMinimize()
    isMinimized = not isMinimized
    if isMinimized then
        minimizeBtn.Text = "+"
        TweenService:Create(window, TweenInfo.new(0.25, Enum.EasingStyle.Quint), {Size = minimizedSize}):Play()
        task.delay(0.2, function() scrolling.Visible = false end)
    else
        minimizeBtn.Text = "−"
        TweenService:Create(window, TweenInfo.new(0.25, Enum.EasingStyle.Quint), {Size = originalSize}):Play()
        task.wait(0.15)
        scrolling.Visible = true
    end
end

minimizeBtn.MouseButton1Click:Connect(toggleMinimize)
