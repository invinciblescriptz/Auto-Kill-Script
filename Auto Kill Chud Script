-- NaN
CreateToggle("NaN", false, function(state)
    local player = game.Players.LocalPlayer
    local targetCFrame = CFrame.new(
        -38.9849625, 0.111833394, 23.6454487,
        0.228692636, 5.38890532e-08, 0.973498702,
        9.52623491e-09, 1, -5.75939509e-08,
        -0.973498702, 2.24450893e-08, 0.228692636
    )

    if _G.NaNLockConnection then
        _G.NaNLockConnection:Disconnect()
        _G.NaNLockConnection = nil
    end

    if state then
        local args = {"changeSize", 0/0}
        game:GetService("ReplicatedStorage"):WaitForChild("rEvents"):WaitForChild("changeSpeedSizeRemote"):InvokeServer(unpack(args))

        local function applyLock(character)
            if not character then return end
            local root = character:WaitForChild("HumanoidRootPart", 5)
            if not root then return end

            root.CFrame = targetCFrame
            root.Anchored = true
            root.Velocity = Vector3.new(0, 0, 0)
            root.RotVelocity = Vector3.new(0, 0, 0)

            if _G.NaNLockConnection then
                _G.NaNLockConnection:Disconnect()
            end

            _G.NaNLockConnection = game:GetService("RunService").Heartbeat:Connect(function()
                if root and root.Parent then
                    root.CFrame = targetCFrame
                    root.Velocity = Vector3.new(0, 0, 0)
                    root.RotVelocity = Vector3.new(0, 0, 0)
                end
            end)
        end

        local character = player.Character or player.CharacterAdded:Wait()
        applyLock(character)

        if not _G.NaNCharacterAddedConn then
            _G.NaNCharacterAddedConn = player.CharacterAdded:Connect(function(newChar)
                task.wait(0.1)
                applyLock(newChar)
            end)
        end

    else
        local character = player.Character
        if character then
            local root = character:FindFirstChild("HumanoidRootPart")
            if root then
                root.Anchored = false
                root.Velocity = Vector3.new(0, 5, 0)
            end
        end

        if _G.NaNLockConnection then
            _G.NaNLockConnection:Disconnect()
            _G.NaNLockConnection = nil
        end

        if _G.NaNCharacterAddedConn then
            _G.NaNCharacterAddedConn:Disconnect()
            _G.NaNCharacterAddedConn = nil
        end
    end
end)

-- Prevent Knockback
CreateToggle("Prevent Knockback", false, function(state)
    getgenv().AntiKnockback = state
    
    if state then
        print("✅ Anti Knockback ENABLED")
        spawn(function()
            while getgenv().AntiKnockback do
                pcall(function()
                    local character = game.Players.LocalPlayer.Character
                    if not character then return end
                    
                    local root = character:FindFirstChild("HumanoidRootPart")
                    if root then
                        for _, v in pairs(root:GetChildren()) do
                            if v:IsA("BodyVelocity") or v:IsA("BodyThrust") or v:IsA("BodyForce") or 
                               v:IsA("LinearVelocity") or v:IsA("VectorForce") then
                                v:Destroy()
                            end
                        end
                    end
                end)
                task.wait(0.03)
            end
        end)
    else
        print("❌ Anti Knockback DISABLED")
    end
end)

